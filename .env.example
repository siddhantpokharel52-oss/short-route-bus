# ============================================================
# KVBMS — Environment Variables Template
# Copy this file to .env and fill in all values.
# NEVER commit .env to version control.
# ============================================================

# Django
SECRET_KEY=your-super-secret-django-key-here-min-50-chars
DEBUG=False
ALLOWED_HOSTS=kvbms.com.np,*.kvbms.com.np,localhost
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Database
DB_NAME=kvbms
DB_USER=kvbms_user
DB_PASSWORD=strong-database-password
DB_HOST=db
DB_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=strong-redis-password

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-separate-from-django-key
JWT_ACCESS_EXPIRY_MINUTES=60
JWT_REFRESH_EXPIRY_DAYS=7

# Email (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@kvbms.com.np
EMAIL_HOST_PASSWORD=

# SMS Gateway (Sparrow SMS or Nepal Telecom)
SMS_API_KEY=
SMS_API_URL=https://api.sparrowsms.com/v2/sms/

# Firebase Cloud Messaging (Push Notifications)
FCM_SERVER_KEY=

# Payment Gateways
ESEWA_MERCHANT_ID=
KHALTI_SECRET_KEY=
FONEPAY_MERCHANT_ID=

# AWS S3 (File Storage)
AWS_S3_BUCKET=kvbms-uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_REGION_NAME=ap-south-1

# Sentry (Error Tracking)
SENTRY_DSN=

# Baato Maps (map tiles + routing)
# Get a key at https://baato.io/
VITE_BAATO_API_KEY=
